<Page
    x:Class="WeatherAppRT2._0.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WeatherAppRT2._0"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    RequestedTheme="Light"
    Background="#FFE8F0FE">

    <Grid>
        <!-- 天空渐变背景 -->
        <Grid VerticalAlignment="Top" Height="260">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF81D4FA" Offset="0.0"/>
                    <GradientStop Color="#FFB3E5FC" Offset="0.3"/>
                    <GradientStop Color="#FFE1F5FE" Offset="0.65"/>
                    <GradientStop Color="#FFF0F4FA" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,60,0,0">
            <StackPanel Margin="18,12,18,18">

                <!-- 标题 -->
                <TextBlock Text="设置" FontSize="28" FontWeight="SemiLight"
                           Foreground="#FF1A237E" Margin="0,0,0,20"/>

                <!-- ===== 刷新频率 ===== -->
                <TextBlock Text="后台刷新" FontSize="14" FontWeight="SemiLight"
                           Foreground="#FF607D8B" Margin="0,0,0,8"/>

                <Border Background="#CCFFFFFF" CornerRadius="14" Padding="16,14"
                        Margin="0,0,0,16" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="天气数据刷新间隔" FontSize="15" FontWeight="SemiLight"
                                   Foreground="#FF1A237E"/>
                        <TextBlock x:Name="RefreshIntervalLabel" FontSize="12"
                                   Foreground="#FF90A4AE" Margin="0,2,0,10"/>
                        <Slider x:Name="RefreshIntervalSlider"
                                Minimum="15" Maximum="120" Value="30"
                                StepFrequency="15" SmallChange="15"
                                ValueChanged="OnRefreshIntervalChanged"/>
                        <Grid>
                            <TextBlock Text="15分钟" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Left"/>
                            <TextBlock Text="120分钟" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== 通知开关 ===== -->
                <TextBlock Text="天气通知" FontSize="14" FontWeight="SemiLight"
                           Foreground="#FF607D8B" Margin="0,0,0,8"/>

                <Border Background="#CCFFFFFF" CornerRadius="14" Padding="16,14"
                        Margin="0,0,0,16" BorderBrush="#30FFFFFF" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用天气变化通知" FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E"/>
                            <TextBlock Text="天气显著变化时推送 Toast 通知"
                                       FontSize="12" Foreground="#FF90A4AE" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="NotifyToggle" Grid.Column="1"
                                      OnContent="" OffContent=""
                                      Toggled="OnNotifyToggled"/>
                    </Grid>
                </Border>

                <!-- ===== 通知间隔 ===== -->
                <Border Background="#CCFFFFFF" CornerRadius="14" Padding="16,14"
                        Margin="0,0,0,16" BorderBrush="#30FFFFFF" BorderThickness="1"
                        x:Name="NotifyIntervalPanel">
                    <StackPanel>
                        <TextBlock Text="通知最小间隔" FontSize="15" FontWeight="SemiLight"
                                   Foreground="#FF1A237E"/>
                        <TextBlock x:Name="NotifyIntervalLabel" FontSize="12"
                                   Foreground="#FF90A4AE" Margin="0,2,0,10"/>
                        <Slider x:Name="NotifyIntervalSlider"
                                Minimum="15" Maximum="240" Value="60"
                                StepFrequency="15" SmallChange="15"
                                ValueChanged="OnNotifyIntervalChanged"/>
                        <Grid>
                            <TextBlock Text="15分钟" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Left"/>
                            <TextBlock Text="4小时" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== 通知阈值 ===== -->
                <TextBlock x:Name="NotifyThresholdTitle" Text="通知触发条件" FontSize="14" FontWeight="SemiLight"
                           Foreground="#FF607D8B" Margin="0,0,0,8"/>

                <!-- 温度变化阈值 -->
                <Border Background="#CCFFFFFF" CornerRadius="14" Padding="16,14"
                        Margin="0,0,0,8" BorderBrush="#30FFFFFF" BorderThickness="1"
                        x:Name="TempThresholdPanel">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="温度变化 ≥ " FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TempThresholdLabel" Text="3°C" FontSize="15"
                                       FontWeight="SemiLight" Foreground="#FFFF8C00"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" 时通知" FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Slider x:Name="TempThresholdSlider"
                                Minimum="1" Maximum="10" Value="3"
                                StepFrequency="1"
                                ValueChanged="OnTempThresholdChanged" Margin="0,6,0,0"/>
                        <Grid>
                            <TextBlock Text="1°C" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Left"/>
                            <TextBlock Text="10°C" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 降水概率阈值 -->
                <Border Background="#CCFFFFFF" CornerRadius="14" Padding="16,14"
                        Margin="0,0,0,8" BorderBrush="#30FFFFFF" BorderThickness="1"
                        x:Name="RainThresholdPanel">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="降水概率 ≥ " FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RainThresholdLabel" Text="50%" FontSize="15"
                                       FontWeight="SemiLight" Foreground="#FF00BCD4"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" 时通知" FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Slider x:Name="RainThresholdSlider"
                                Minimum="10" Maximum="90" Value="50"
                                StepFrequency="10"
                                ValueChanged="OnRainThresholdChanged" Margin="0,6,0,0"/>
                        <Grid>
                            <TextBlock Text="10%" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Left"/>
                            <TextBlock Text="90%" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 大风阈值 -->
                <Border Background="#CCFFFFFF" CornerRadius="14" Padding="16,14"
                        Margin="0,0,0,8" BorderBrush="#30FFFFFF" BorderThickness="1"
                        x:Name="WindThresholdPanel">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="风速 ≥ " FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E" VerticalAlignment="Center"/>
                            <TextBlock x:Name="WindThresholdLabel" Text="20 km/h" FontSize="15"
                                       FontWeight="SemiLight" Foreground="#FFEF5350"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text=" 时通知" FontSize="15" FontWeight="SemiLight"
                                       Foreground="#FF1A237E" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Slider x:Name="WindThresholdSlider"
                                Minimum="5" Maximum="50" Value="20"
                                StepFrequency="5"
                                ValueChanged="OnWindThresholdChanged" Margin="0,6,0,0"/>
                        <Grid>
                            <TextBlock Text="5 km/h" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Left"/>
                            <TextBlock Text="50 km/h" FontSize="11" Foreground="#FF90A4AE" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 底部留白 -->
                <Border Height="40"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
